{
  "name": "Pinta QGIS devcontainer (X11)",
  "dockerComposeFile": [
    "docker-compose.devcontainer.yml"
  ],
  "workspaceFolder": "/home/ubuntu/workspace",
  "service": "devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    },
    "jetbrains": {
      "backend" : "IntelliJ",
      "extensions": [
        "PythonCore",
        "Pythonid",
        "insyncwithfoo.ryecharm",
        "intellij.python.dap.plugin"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git" : {},
    "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {}
  },
  "postCreateCommand": "bash .devcontainer/setup_venv.sh"
}
